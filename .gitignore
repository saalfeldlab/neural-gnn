# Data files (large simulation data)
*.npy
*.npz
*.pth
*.backup
paper/

# Log folder - include models/*.pt and connectivity.pt, exclude everything else
log/**/*
!log/signal/
!log/signal/*/
!log/signal/**/models/
!log/signal/**/models/*.pt
!log/signal/*/connectivity.pt

# Ignore edge_index.pt and mask.pt everywhere (recreated from connectivity.pt)
**/edge_index.pt
**/mask.pt

# Exclude signal_fig_supp_11 large files (>100MB exceed GitHub limit)
log/signal/signal_fig_supp_11/models/
log/signal/signal_fig_supp_11/connectivity.pt
graphs_data/signal/signal_fig_supp_11/connectivity.pt

# graphs_data: include connectivity.pt, exclude .npy, .backup, .png, and generated files
graphs_data/**/*.npy
graphs_data/**/*.backup
graphs_data/**/*.png
graphs_data/**/analysis.log
graphs_data/**/X1.pt
graphs_data/**/X_msg.pt

# Explicitly track connectivity.pt and video_bisons_32.tif
!graphs_data/signal/*/connectivity.pt
!graphs_data/video_bisons_32.tif

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Quarto
/.quarto/
_site/
*.quarto_ipynb
*_files/
*.ipynb

**/*.quarto_ipynb
